    /ImageMatrix [ 1 0 0 -1 0 600 ] def
  end
  /MaskDict 8 dict def
     MaskDict begin
    /ImageType 1 def
    /Width 630 def
    /Height 600 def
    /Interpolate true def
    /BitsPerComponent 1 def
    /Decode [ 1 0 ] def
    /ImageMatrix [ 1 0 0 -1 0 600 ] def
  end
end
